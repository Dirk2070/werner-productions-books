---
import { loadBooks } from "../lib/load-books.js";
import SiteHeader from "../components/SiteHeader.astro";
import IndexHero from "../components/IndexHero.astro";
import BookGrid from "../components/BookGrid.astro";
import AppsSection from "../components/AppsSection.astro";
import SocialLinks from "../components/SocialLinks.astro";
import FaqSection from "../components/FaqSection.astro";
import PressQuote from "../components/PressQuote.astro";
import FocusBadge from "../components/FocusBadge.astro";
import CrossLinkingFooter from "../components/CrossLinkingFooter.astro";
import SiteFooter from "../components/SiteFooter.astro";

const books = await loadBooks();

const BASE_URL = "https://books.werner-productions.com";

// JSON-LD: Person + WebSite + ProfilePage @graph (commit 65ee79e — DO NOT MODIFY)
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": `${BASE_URL}/#author`,
      "name": "Dirk Werner",
      "givenName": "Dirk",
      "familyName": "Werner",
      "jobTitle": "Diplom-Psychologe, Psychotherapeut, Autor, Digital Creator",
      "description": "Dirk Werner ist Diplom-Psychologe, Psychotherapeut, Autor psychologischer Sachbücher und Romane sowie Digital Creator von psychologischen Apps und Social Media Content.",
      "image": `${BASE_URL}/assets/dirk-werner.jpg`,
      "url": BASE_URL,
      "sameAs": [
        "https://orcid.org/0009-0001-7822-0041",
        "https://d-nb.info/gnd/1384382429",
        "https://www.goodreads.com/author/show/70076437",
        "https://dirkwernerbooks.com",
        "https://werner-productions.com",
        "https://shadow-integrator.com",
        "https://psyprofiler.com",
        "https://insightvue.app",
        "https://www.amazon.de/stores/Dirk-Werner/author/B0F2YNKR78",
        "https://play.google.com/store/books/author?id=Dirk+Werner",
        "https://books.apple.com/us/author/dirk-werner/id1800990912",
        "https://www.youtube.com/@LuxMesopotamiae-kw6rw",
        "https://www.youtube.com/@dirkwerner777",
        "https://www.instagram.com/dirk.werner.d.w.2070/",
        "https://www.threads.net/@dirk.werner.d.w.2070",
        "https://www.tiktok.com/@innergrowthguide5",
        "https://x.com/dirk_werner1",
        "https://twitter.com/LuxMesopotamiae",
        "https://de.linkedin.com/in/dirk-werner-657a81a8",
        "https://www.xing.com/profile/Dirk_Werner12"
      ],
      "knowsAbout": [
        "Psychologie",
        "Psychotherapie",
        "Jungianische Psychologie",
        "Persönlichkeitsentwicklung",
        "Fantasy-Literatur",
        "Psychothriller"
      ],
      "hasOccupation": {
        "@type": "Occupation",
        "name": "Psychologischer Psychotherapeut",
        "occupationalCategory": "Psychotherapy",
        "qualifications": "Diplom-Psychologe, Approbation als Psychologischer Psychotherapeut (Verhaltenstherapie), Zusatzqualifikationen in Gestalt-, Körper- und personenzentrierter Therapie"
      },
      "workLocation": {
        "@id": `${BASE_URL}/#practice`
      },
      "award": [
        "FOCUS-Empfehlung Gesundheit 2023 für Psychotherapie",
        "FOCUS-Empfehlung Gesundheit 2025 für Psychotherapie"
      ]
    },
    {
      "@type": ["MedicalBusiness", "ProfessionalService"],
      "@id": `${BASE_URL}/#practice`,
      "name": "Praxis Dirk Werner — Psychologischer Psychotherapeut",
      "founder": { "@id": `${BASE_URL}/#author` },
      "employee": { "@id": `${BASE_URL}/#author` },
      "medicalSpecialty": "Psychiatric",
      "areaServed": {
        "@type": "AdministrativeArea",
        "name": "Allgäu, Bayern"
      },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Füssen-Hopfen am See",
        "addressRegion": "Bayern",
        "addressCountry": "DE"
      },
      "url": "https://werner-productions.com/",
      "award": [
        "FOCUS-Empfehlung Gesundheit 2023 für Psychotherapie",
        "FOCUS-Empfehlung Gesundheit 2025 für Psychotherapie"
      ],
      "hasCredential": [
        {
          "@type": "EducationalOccupationalCredential",
          "credentialCategory": "Award",
          "name": "FOCUS-Empfehlung Gesundheit 2023 — Psychotherapie",
          "recognizedBy": { "@type": "Organization", "name": "FOCUS-Gesundheit" },
          "dateCreated": "2023"
        },
        {
          "@type": "EducationalOccupationalCredential",
          "credentialCategory": "Award",
          "name": "FOCUS-Empfehlung Gesundheit 2025 — Psychotherapie",
          "recognizedBy": { "@type": "Organization", "name": "FOCUS-Gesundheit" },
          "dateCreated": "2025"
        }
      ]
    },
    {
      "@type": "WebSite",
      "@id": `${BASE_URL}/#website`,
      "url": BASE_URL,
      "name": "Werner Productions Books",
      "description": "Bücher von Dirk Werner — Psychologie, Persönlichkeitsentwicklung und Fantasy",
      "publisher": {
        "@id": `${BASE_URL}/#author`
      },
      "inLanguage": ["de", "en"]
    },
    {
      "@type": "ProfilePage",
      "@id": `${BASE_URL}/#profilepage`,
      "url": BASE_URL,
      "name": "Dirk Werner — Autor-Profil",
      "isPartOf": {
        "@id": `${BASE_URL}/#website`
      },
      "about": {
        "@id": `${BASE_URL}/#author`
      },
      "mainEntity": {
        "@id": `${BASE_URL}/#author`
      }
    }
  ]
};
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Dirk Werner — Bücher, Psychologie & Apps</title>
  <meta name="description" content="Bücher von Dirk Werner: Psychologie, Persönlichkeitsentwicklung und Fantasy-Romane. Diplom-Psychologe, Psychotherapeut, Autor." />
  <meta name="author" content="Dirk Werner" />
  <link rel="canonical" href={BASE_URL + "/"} />

  <!-- Open Graph -->
  <meta property="og:title" content="Dirk Werner — Bücher, Psychologie & Apps" />
  <meta property="og:description" content="Bücher von Dirk Werner: Psychologie, Persönlichkeitsentwicklung und Fantasy-Romane." />
  <meta property="og:type" content="profile" />
  <meta property="og:locale" content="de_DE" />
  <meta property="og:url" content={BASE_URL + "/"} />
  <meta property="og:image" content={BASE_URL + "/assets/dirk-werner.jpg"} />

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <link rel="stylesheet" href="/styles/book-detail.css" />
</head>
<body>
  <SiteHeader variant="full" />
  <main>
    <IndexHero />
    <BookGrid books={books} />
    <AppsSection />
    <SocialLinks />
    <FaqSection />
    <PressQuote />
    <FocusBadge />
  </main>
  <CrossLinkingFooter />
  <SiteFooter />
</body>
</html>
