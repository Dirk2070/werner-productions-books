---
const title = "FOCUS-Empfehlung";
const body = "FOCUS-Empfehlung Gesundheit 2023 & 2025 für Psychotherapie. Unabhängige Bewertung nach Praxiserfahrung, Therapiespektrum und Reputation.";
---

<section class="focus-badge" aria-label="Auszeichnung">
  <div class="focus-badge__inner">
    <span class="focus-badge__label">Auszeichnung</span>
    <h2 class="focus-badge__title">{title}</h2>
    <p class="focus-badge__body">{body}</p>
  </div>
</section>

<style>
  .focus-badge {
    padding: 2rem 1.5rem;
    background: #0e0e22;
    border-top: 1px solid #2d2d4e;
  }
  .focus-badge__inner {
    max-width: 960px;
    margin: 0 auto;
  }
  .focus-badge__label {
    display: inline-block;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: #c9a96e;
    margin: 0 0 0.5rem;
  }
  .focus-badge__title {
    font-size: 1.4rem;
    font-weight: 700;
    color: #e8e0f0;
    margin: 0 0 0.75rem;
    font-family: Georgia, "Times New Roman", serif;
  }
  .focus-badge__body {
    margin: 0;
    color: #b0a0d0;
    font-size: 0.95rem;
    line-height: 1.6;
  }
</style>
