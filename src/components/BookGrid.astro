---
import type { Book } from "../lib/load-books.js";

interface Props {
  books: Book[];
}

const { books } = Astro.props;

// Sort by dateModified desc, fallback alphabetical
const sorted = [...books].sort((a, b) => {
  if (a.dateModified && b.dateModified) {
    return b.dateModified.localeCompare(a.dateModified);
  }
  if (a.dateModified) return -1;
  if (b.dateModified) return 1;
  return a.title.localeCompare(b.title);
});

function formatBadges(book: Book): string[] {
  const badges: string[] = [];
  const formats = book.workExample.map((e) => e.format);
  if (formats.includes("ebook")) badges.push("📱 E-Book");
  if (formats.includes("paperback") || formats.includes("hardcover")) badges.push("📚 Paperback");
  if (formats.includes("audiobook")) badges.push("🎧 Hörbuch");
  return badges;
}
---

<section class="book-grid" id="books">
  <div class="book-grid__inner">
    <ul class="book-grid__list">
      {sorted.map((book, i) => {
        const badges = formatBadges(book);
        return (
          <li class="book-grid__item">
            <a href={`/${book.slug}/`} class="book-grid__link">
              <div class="book-grid__cover-wrap">
                <img
                  src={`/${book.cover.filename}`}
                  alt={book.cover.alt}
                  width="200"
                  height="320"
                  loading={i < 4 ? "eager" : "lazy"}
                  class="book-grid__cover"
                  onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
                />
                <div class="book-grid__cover-fallback" style="display:none">
                  <span>{book.title}</span>
                </div>
              </div>
              <div class="book-grid__meta">
                <p class="book-grid__title">{book.title}</p>
                {badges.length > 0 && (
                  <ul class="book-grid__badges">
                    {badges.map((b) => (
                      <li class="book-grid__badge">{b}</li>
                    ))}
                  </ul>
                )}
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</section>

<style>
  .book-grid {
    padding: 2rem 1.5rem;
  }
  .book-grid__inner {
    max-width: 1100px;
    margin: 0 auto;
  }
  .book-grid__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  @media (min-width: 540px) {
    .book-grid__list {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (min-width: 768px) {
    .book-grid__list {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  @media (min-width: 960px) {
    .book-grid__list {
      grid-template-columns: repeat(5, 1fr);
    }
  }
  .book-grid__link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    gap: 0.5rem;
  }
  .book-grid__cover-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 200 / 320;
    overflow: hidden;
    border-radius: 4px;
    background: #1e1e38;
  }
  .book-grid__cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.2s;
  }
  .book-grid__link:hover .book-grid__cover {
    transform: scale(1.03);
  }
  .book-grid__cover-fallback {
    position: absolute;
    inset: 0;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    background: #1e1e38;
    color: #7060a0;
    font-size: 0.75rem;
    text-align: center;
  }
  .book-grid__meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .book-grid__title {
    margin: 0;
    color: #d0c8e8;
    font-size: 0.8rem;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    font-weight: 600;
  }
  .book-grid__link:hover .book-grid__title {
    color: #c9a96e;
  }
  .book-grid__badges {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.2rem;
  }
  .book-grid__badge {
    font-size: 0.65rem;
    color: #7060a0;
    white-space: nowrap;
  }
</style>
