---
import type { Book } from "../lib/load-books.js";

interface Props {
  book: Book;
  allBooks: Book[];
}
const { book, allBooks } = Astro.props;

const translationSlugs = [
  ...book.workTranslation,
  ...book.translationOfWork,
];

const translations = translationSlugs
  .map((slug) => allBooks.find((b) => b.slug === slug))
  .filter((b): b is Book => !!b);
---
{translations.length > 0 && (
  <section class="book-translation">
    <div class="book-translation__inner">
      <h2 class="book-translation__heading">Weitere Ausgaben</h2>
      <ul class="book-translation__list">
        {translations.map((t) => (
          <li class="book-translation__item">
            <a class="book-translation__link" href={`/${t.slug}/`}>
              <img
                class="book-translation__cover"
                src={`/${t.cover.filename}`}
                alt={t.cover.alt}
                width="60"
                height="96"
                loading="lazy"
              />
              <span class="book-translation__info">
                <span class="book-translation__lang">
                  {t.language === "en" ? "English Edition" : "Deutsche Ausgabe"}
                </span>
                <span class="book-translation__title">{t.title}</span>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
)}

<style>
  .book-translation {
    padding: 2rem 1.5rem;
    background: #1a1a2e;
    border-top: 1px solid #2d2d4e;
  }
  .book-translation__inner {
    max-width: 960px;
    margin: 0 auto;
  }
  .book-translation__heading {
    font-size: 1rem;
    font-weight: 700;
    color: #c9a96e;
    margin: 0 0 1rem;
  }
  .book-translation__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .book-translation__link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    background: #2d2d4e;
    padding: 0.75rem;
    border-radius: 4px;
    border: 1px solid #3d3d6e;
    transition: border-color 0.2s;
  }
  .book-translation__link:hover {
    border-color: #c9a96e;
  }
  .book-translation__cover {
    border-radius: 2px;
    object-fit: cover;
  }
  .book-translation__info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .book-translation__lang {
    font-size: 0.75rem;
    color: #7060a0;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .book-translation__title {
    color: #e0d8f8;
    font-size: 0.9rem;
    font-weight: 600;
  }
</style>
