---
const orcid = "0009-0001-7822-0041";
const gnd = "1384382429";
const email = "werner-productions-media@protonmail.com";
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="site-footer__inner">
    <nav class="site-footer__links">
      <a href="/impressum/">Impressum</a>
      <a href="/datenschutz/">Datenschutz</a>
      <a href="/llms.txt">llms.txt</a>
      <a href={`mailto:${email}`}>{email}</a>
      <a href={`https://orcid.org/${orcid}`} rel="noopener" aria-label="ORCID">
        ORCID {orcid}
      </a>
      <a href={`https://d-nb.info/gnd/${gnd}`} rel="noopener" aria-label="GND">
        GND {gnd}
      </a>
    </nav>
    <p class="site-footer__copy">
      &copy; {year} Werner Productions · Dirk Werner · Füssen, Deutschland
    </p>
  </div>
</footer>

<style>
  .site-footer {
    background: #0e0e1c;
    border-top: 1px solid #1e1e38;
    padding: 1.5rem;
    margin-top: 0;
  }
  .site-footer__inner {
    max-width: 960px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: center;
    text-align: center;
  }
  .site-footer__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    justify-content: center;
  }
  .site-footer__links a {
    color: #6050a0;
    font-size: 0.8rem;
    text-decoration: none;
  }
  .site-footer__links a:hover {
    color: #c9a96e;
    text-decoration: underline;
  }
  .site-footer__copy {
    color: #3d3060;
    font-size: 0.75rem;
    margin: 0;
  }
</style>
